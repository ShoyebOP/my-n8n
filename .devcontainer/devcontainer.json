{
  "name": "n8n codespace",
  "dockerComposeFile": "compose.yaml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "forwardPorts": [5678],

  "portsAttributes": {
    "5678": {
      "label": "n8n UI",
      "onAutoForward": "openPreview",
      "visibility": "public" 
    }
  },

  "postCreateCommand": "mkdir -p local-files",
  
  "postStartCommand": "docker compose pull && docker compose up -d && gh codespace ports visibility 5678:public -c $CODESPACE_NAME",

  "shutdownAction": "stopCompose"
}
