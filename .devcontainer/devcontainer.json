{
  "name": "n8n Codespace",

  // Use a standard Microsoft-provided image that comes with useful tools.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",

  // This feature is the key. It installs Docker and Docker Compose
  // inside your Codespace, allowing you to run your services.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // This command runs AFTER the container is created.
  // It will build and start your n8n services in the background.
  "postCreateCommand": "docker-compose -f compose.yaml up -d --build",

  // This keeps your VS Code terminal from closing after the command runs.
  "shutdownAction": "none",

  // Forward the n8n port so you can access it.
  "forwardPorts": [5678],

  // Configure the forwarded port to open in your browser automatically.
  "portsAttributes": {
    "5678": {
      "label": "n8n",
      "onAutoForward": "openBrowser"
    }
  }
}
