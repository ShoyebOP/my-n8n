{
  "name": "n8n Codespace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },

  // Runs ONLY ONCE after the Codespace is created or rebuilt.
  // This is the perfect place to do the heavy lifting of building your images.
  "postCreateCommand": "docker-compose -f compose.yaml up -d --build",

  // Runs EVERY TIME the Codespace starts or resumes.
  // This command is fast. It just starts your services if they are stopped.
  "postStartCommand": "docker-compose -f compose.yaml up -d --build",

  "shutdownAction": "none"
}
