{
  "name": "n8n Codespace",

  // 1. Use a standard base image.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",

  // 2. Add the Docker-in-Docker feature.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // 3. Run your compose file AFTER the Codespace is fully created.
  // This is the most important part.
  "postCreateCommand": "docker-compose -f compose.yaml up -d --build",

  // 4. Keep the container running.
  "shutdownAction": "none",

  // 5. Forward the n8n port.
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n",
      "onAutoForward": "openBrowser"
    }
  }
}
